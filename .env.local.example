# ---------------------------------------------------------------------------
# Contact form email delivery (Gmail SMTP via Nodemailer)
#   Copy this file to `.env.local` and fill in the values.
# ---------------------------------------------------------------------------
# To receive enquiries in your Gmail you need a Google "App Password":
#
# 1. Turn ON 2-Step Verification for the Gmail account:
#      https://myaccount.google.com/security
# 2. Create an App Password (choose "Mail" / "Other"):
#      https://myaccount.google.com/apppasswords
# 3. Google shows a 16-character password like: abcd efgh ijkl mnop
#    Paste it below WITHOUT spaces, then restart `npm run dev`.
#
# These values are only read on the server (never sent to the browser).

GMAIL_USER=sagesaimagency@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Where enquiry notifications are delivered (defaults to GMAIL_USER).
CONTACT_TO_EMAIL=sagesaimagency@gmail.com
